# Environment Variables for RAG Knowledge Assistant
# Copy to .env and fill in your values: cp .env.example .env

# ── Required ──────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Backend ───────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Frontend ──────────────────────────────────────────────
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=8501

# Frontend → Backend URL (required for Railway / production)
# Local dev: http://localhost:8000
# Railway:   https://<your-backend-service>.up.railway.app
API_BASE_URL=http://localhost:8000

# ── ChromaDB ──────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data

# ── Optional ──────────────────────────────────────────────
LOG_LEVEL=INFO
CORS_ORIGINS=*
